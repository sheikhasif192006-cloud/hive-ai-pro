{
  "name": "hive-desktop",
  "version": "1.0.0",
  "description": "HIVE.AI - Next-Gen 3D Engine",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.hive.ai",
    "productName": "HIVE.AI Slicer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "../backend/**/*",
      "../frontend/index.html"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  },
  "keywords": [
    "3d",
    "slicer",
    "ai",
    "hive"
  ],
  "author": "HIVE Team",
  "license": "ISC",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}